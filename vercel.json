{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/calibrate", "schedule": "0 6 * * *" }
  ],
  "rewrites": [
    { "source": "/instalar", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/cron/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/matches/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, s-maxage=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, s-maxage=1800, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/api/odds/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=120" }
      ]
    }
  ]
}
